---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import PlazoBadge from "../../components/PlazoBadge.astro";
import { products, productBySlug, formatPrice, productsByOcasion } from "../../data/products";
import { ocasionBySlug } from "../../data/ocasiones";
import { waLink, SITE_URL } from "../../lib/whatsapp";

export const getStaticPaths = () =>
  products.map((p) => ({ params: { slug: p.slug } }));

const { slug } = Astro.params;
const product = productBySlug(slug!)!;
const ocasion = ocasionBySlug(product.ocasion)!;
const relacionados = productsByOcasion(product.ocasion).filter((p) => p.slug !== product.slug).slice(0, 3);

const waComprar = waLink({ kind: "comprar", productName: product.nombre, productSlug: product.slug });
const waDuda = waLink({ kind: "duda", productName: product.nombre, productSlug: product.slug });

const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  name: product.nombre,
  description: product.descripcionCorta,
  image: new URL(product.imagen, SITE_URL).toString(),
  brand: { "@type": "Brand", name: "LáserCrafts" },
  offers: {
    "@type": "Offer",
    priceCurrency: "CLP",
    price: product.precio,
    availability: "https://schema.org/InStock",
    url: new URL(`/producto/${product.slug}`, SITE_URL).toString()
  }
};
---

<BaseLayout
  title={`${product.nombre} — LáserCrafts`}
  description={product.descripcionCorta}
  ogImage={product.imagen}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(productSchema)}></script>

  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a> <span>›</span>
      <a href="/productos">Productos</a> <span>›</span>
      <a href={`/productos/${ocasion.slug}`}>{ocasion.nombre}</a> <span>›</span>
      <span aria-current="page">{product.nombre}</span>
    </nav>

    <div class="pdp">
      <section class="galeria" aria-label="Imágenes del producto">
        <div class="galeria-main">
          <img src={product.imagen} alt={product.nombre} id="img-principal" />
        </div>
        <div class="galeria-thumbs" role="list">
          {[product.imagen, "/img/products/cofre.svg", "/img/products/tabla-quesos.svg", "/img/products/marco-foto.svg"].map((src, i) => (
            <button class="thumb" data-src={src} aria-label={`Imagen ${i + 1}`}>
              <img src={src} alt="" />
            </button>
          ))}
        </div>
      </section>

      <section class="info" aria-label="Información del producto">
        <p class="ocasion-tag">
          <a href={`/productos/${ocasion.slug}`}>{ocasion.nombre}</a>
        </p>
        <h1>{product.nombre}</h1>
        <p class="precio">{formatPrice(product.precio)}</p>
        <p class="descripcion-corta">{product.descripcionCorta}</p>

        <div class="opciones" aria-label="Opciones de personalización">
          <div class="opcion">
            <label for="opt-texto">{product.opciones.texto.label}</label>
            <input id="opt-texto" type="text" placeholder={product.opciones.texto.placeholder} />
            <p class="hint">Lo que escribas aquí va al grabado. Lo confirmamos por WhatsApp antes de producir.</p>
          </div>

          <div class="opcion opcion-row">
            <div>
              <label for="opt-cantidad">Cantidad</label>
              <input id="opt-cantidad" type="number" min={product.opciones.cantidad.min} max={product.opciones.cantidad.max} value={product.opciones.cantidad.default} />
            </div>
          </div>
        </div>

        <div class="plazo-bloque">
          <PlazoBadge plazoMax={product.plazoDias.max} />
        </div>

        <div class="ctas">
          <a href={waComprar} target="_blank" rel="noopener" class="btn btn-primary btn-large btn-block" data-wa-context="pdp-comprar">
            Pedir por WhatsApp →
          </a>
          <a href={waDuda} target="_blank" rel="noopener" class="link-duda" data-wa-context="pdp-duda">
            ¿Tienes una duda antes de pedir? Escríbeme →
          </a>
        </div>

        <ul class="confianza">
          <li>📦 Despacho a todo Chile (Chilexpress, Starken, BlueExpress, Correos).</li>
          <li>🪵 Terciado real, grabado a láser. No es impreso, no es vinilo.</li>
          <li>👋 Hecho a mano por Felipe en el taller, no fabricado en serie.</li>
        </ul>
      </section>
    </div>

    <section class="descripcion-larga editorial section">
      <h2>Sobre esta pieza</h2>
      <p>{product.descripcionLarga}</p>
    </section>

    {relacionados.length > 0 && (
      <section class="section">
        <header class="section-header">
          <span class="eyebrow">Para la misma ocasión</span>
          <h2>Otros productos de {ocasion.nombre}</h2>
        </header>
        <div class="grid-rel">
          {relacionados.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll(".thumb").forEach((b) =>
    b.addEventListener("click", (e) => {
      const src = (e.currentTarget as HTMLElement).getAttribute("data-src");
      const main = document.getElementById("img-principal") as HTMLImageElement;
      if (src && main) main.src = src;
    })
  );
</script>

<style>
  .breadcrumb { padding: var(--space-5) 0 var(--space-3); font-size: var(--fs-small); color: var(--color-fieltro); }
  .breadcrumb a { color: var(--color-fieltro); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-profundo); }
  .breadcrumb span { margin: 0 var(--space-1); }

  .pdp {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-5) 0;
  }
  @media (min-width: 900px) {
    .pdp {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-8);
      align-items: start;
    }
  }
  .galeria-main {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-tile);
    background: var(--color-nogal-12);
    margin-bottom: var(--space-3);
  }
  .galeria-main img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.2s ease; }
  .galeria-thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-2); }
  .thumb { aspect-ratio: 1 / 1; border-radius: var(--radius-card); overflow: hidden; padding: 0; border: 1px solid var(--color-profundo-08); background: var(--color-nogal-12); cursor: pointer; }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb:hover { border-color: var(--color-profundo-16); }

  .ocasion-tag { font-family: var(--font-mono); font-size: var(--fs-micro); text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-fieltro); margin: 0 0 var(--space-2); }
  .ocasion-tag a { color: inherit; text-decoration: none; }
  .ocasion-tag a:hover { color: var(--color-profundo); }

  .info h1 { font-size: var(--fs-h1); margin-bottom: var(--space-3); }
  .precio { font-family: var(--font-display); font-weight: 700; font-size: var(--fs-h2); color: var(--color-profundo); margin: 0 0 var(--space-4); }
  .descripcion-corta { color: var(--color-fieltro); font-size: var(--fs-lead); margin-bottom: var(--space-6); }

  .opciones { display: flex; flex-direction: column; gap: var(--space-4); margin-bottom: var(--space-5); padding: var(--space-5); background: var(--color-papel); border: 1px solid var(--color-profundo-08); border-radius: var(--radius-tile); }
  .opcion { display: flex; flex-direction: column; gap: var(--space-2); }
  .opcion-row { flex-direction: row; gap: var(--space-4); }
  .opcion label { font-weight: 500; font-size: var(--fs-small); color: var(--color-profundo); }
  .opcion input { padding: var(--space-3); border: 1px solid var(--color-profundo-16); border-radius: var(--radius-card); font-family: inherit; font-size: var(--fs-body); background: var(--color-papel); color: var(--color-profundo); }
  .opcion input:focus-visible { outline: 2px solid var(--color-profundo); outline-offset: 1px; }
  .opcion-row input[type="number"] { width: 120px; }
  .hint { font-size: var(--fs-micro); color: var(--color-fieltro); margin: 0; }

  .plazo-bloque { margin-bottom: var(--space-5); }

  .ctas { display: flex; flex-direction: column; align-items: stretch; gap: var(--space-3); margin-bottom: var(--space-6); }
  .link-duda { display: inline-block; text-align: center; color: var(--color-profundo); text-decoration: underline; font-size: var(--fs-small); padding: var(--space-2); }
  .link-duda:hover { color: var(--color-fieltro); }

  .confianza { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); font-size: var(--fs-small); color: var(--color-fieltro); border-top: 1px solid var(--color-profundo-08); padding-top: var(--space-4); }

  .descripcion-larga { padding-top: var(--space-7); padding-bottom: var(--space-3); }
  .descripcion-larga h2 { margin-bottom: var(--space-3); }
  .descripcion-larga p { font-size: var(--fs-lead); color: var(--color-fieltro); max-width: 60ch; }

  .section-header { margin-bottom: var(--space-6); max-width: 62ch; }
  .grid-rel { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 700px) { .grid-rel { grid-template-columns: repeat(3, 1fr); } }
</style>
