---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { productsByOcasion } from "../../data/products";
import { ocasiones, ocasionBySlug } from "../../data/ocasiones";
import { waLink } from "../../lib/whatsapp";

export const getStaticPaths = () =>
  ocasiones.map((o) => ({ params: { ocasion: o.slug } }));

const { ocasion: slug } = Astro.params;
const ocasion = ocasionBySlug(slug!);
if (!ocasion) {
  return Astro.redirect("/productos");
}
const productos = productsByOcasion(slug!);
const wa = waLink({ kind: "ocasion", ocasion: ocasion.nombre });
---

<BaseLayout
  title={`${ocasion.nombre} — Regalos personalizados | LáserCrafts`}
  description={ocasion.descripcion}
>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a> <span>›</span>
      <a href="/productos">Productos</a> <span>›</span>
      <span aria-current="page">{ocasion.nombre}</span>
    </nav>

    <header class="page-header">
      <span class="eyebrow">{productos.length} productos</span>
      <h1>{ocasion.nombre}</h1>
      <p class="lead">{ocasion.copyHero}</p>
    </header>

    <div class="filtros" role="navigation" aria-label="Filtros por ocasión">
      <a href="/productos" class="filtro">Todos</a>
      {ocasiones.map((o) => (
        <a href={`/productos/${o.slug}`} class:list={["filtro", o.slug === slug && "filtro-active"]}>{o.nombre}</a>
      ))}
    </div>

    {productos.length > 0 ? (
      <div class="grid">
        {productos.map((p) => <ProductCard product={p} />)}
      </div>
    ) : (
      <div class="empty">
        <h2>Por ahora no tenemos productos para esta ocasión.</h2>
        <p>Pero igual lo podemos resolver. Escríbeme y conversamos.</p>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary" data-wa-context="empty-ocasion">
          Escribir por WhatsApp
        </a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .breadcrumb { padding: var(--space-5) 0 var(--space-3); font-size: var(--fs-small); color: var(--color-fieltro); }
  .breadcrumb a { color: var(--color-fieltro); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-profundo); }
  .breadcrumb span { margin: 0 var(--space-1); }
  .page-header { padding-bottom: var(--space-5); }
  .page-header h1 { margin-bottom: var(--space-3); }
  .page-header .lead { color: var(--color-fieltro); font-size: var(--fs-lead); margin: 0; }
  .filtros { display: flex; flex-wrap: wrap; gap: var(--space-2); padding: var(--space-3) 0 var(--space-6); border-bottom: 1px solid var(--color-profundo-08); margin-bottom: var(--space-6); }
  .filtro { padding: var(--space-2) var(--space-3); border-radius: var(--radius-pill); background: var(--color-papel); color: var(--color-profundo); text-decoration: none; font-size: var(--fs-small); font-weight: 500; border: 1px solid var(--color-profundo-16); }
  .filtro:hover { background: var(--color-profundo-08); }
  .filtro-active { background: var(--color-profundo); color: var(--color-papel); border-color: var(--color-profundo); }
  .grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); padding-bottom: var(--space-9); }
  @media (min-width: 600px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  .empty { padding: var(--space-8) 0; text-align: center; }
  .empty h2 { max-width: 24ch; margin: 0 auto var(--space-3); }
  .empty p { color: var(--color-fieltro); margin-bottom: var(--space-5); }
</style>
