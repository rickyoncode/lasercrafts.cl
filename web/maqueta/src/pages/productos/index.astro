---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { products } from "../../data/products";
import { ocasiones } from "../../data/ocasiones";
---

<BaseLayout
  title="Productos — LáserCrafts"
  description="Catálogo completo de regalos personalizados en terciado grabado a láser. Despacho a todo Chile."
>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a> <span>›</span> <span aria-current="page">Productos</span>
    </nav>

    <header class="page-header">
      <span class="eyebrow">{products.length} productos</span>
      <h1>Todos los productos</h1>
      <p class="lead">Filtra por ocasión, o mira el catálogo entero y elige lo que sirva.</p>
    </header>

    <div class="filtros" role="navigation" aria-label="Filtros por ocasión">
      <a href="/productos" class="filtro filtro-active">Todos</a>
      {ocasiones.map((o) => (
        <a href={`/productos/${o.slug}`} class="filtro">{o.nombre}</a>
      ))}
    </div>

    <div class="grid">
      {products.map((p) => <ProductCard product={p} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    padding: var(--space-5) 0 var(--space-3);
    font-size: var(--fs-small);
    color: var(--color-fieltro);
  }
  .breadcrumb a {
    color: var(--color-fieltro);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--color-profundo);
  }
  .breadcrumb span {
    margin: 0 var(--space-1);
  }

  .page-header {
    padding-bottom: var(--space-5);
    max-width: 62ch;
  }
  .page-header h1 {
    margin-bottom: var(--space-3);
  }
  .page-header .lead {
    color: var(--color-fieltro);
    font-size: var(--fs-lead);
    margin: 0;
  }

  .filtros {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-3) 0 var(--space-6);
    border-bottom: 1px solid var(--color-profundo-08);
    margin-bottom: var(--space-6);
  }
  .filtro {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-pill);
    background: var(--color-papel);
    color: var(--color-profundo);
    text-decoration: none;
    font-size: var(--fs-small);
    font-weight: 500;
    border: 1px solid var(--color-profundo-16);
    transition: background 0.15s ease;
  }
  .filtro:hover {
    background: var(--color-profundo-08);
  }
  .filtro-active {
    background: var(--color-profundo);
    color: var(--color-papel);
    border-color: var(--color-profundo);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-9);
  }
  @media (min-width: 600px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
