---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import OcasionTile from "../components/OcasionTile.astro";
import ClienteFelizCard from "../components/ClienteFelizCard.astro";
import PlazoBadge from "../components/PlazoBadge.astro";
import { products } from "../data/products";
import { ocasiones } from "../data/ocasiones";
import { clientesFelices } from "../data/clientesFelices";
import { waLink } from "../lib/whatsapp";

const top = products.slice(0, 6);
const waCta = waLink({ kind: "home" });
---

<BaseLayout
  title="LáserCrafts — Regalo personalizado en madera. Despacho a todo Chile."
  description="Taller chileno de regalo personalizado en terciado grabado a láser. Hecho a mano por Felipe, despacho a todo Chile, listo en días."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Regalo en madera · Taller en el sur de Chile</span>
        <h1>¿Y si mejor lo hacemos bien?</h1>
        <p class="lead">
          Regalo personalizado en terciado grabado a láser. Hecho a mano por
          Felipe, en una pieza a la vez. Despacho a todo Chile, listo en días.
        </p>
        <div class="hero-plazo">
          <PlazoBadge plazoMax={5} />
        </div>
        <div class="hero-actions">
          <a href="/productos" class="btn btn-primary btn-large">Ver productos</a>
          <a href={waCta} target="_blank" rel="noopener" class="btn btn-ghost btn-large" data-wa-context="hero">
            Conversemos por WhatsApp
          </a>
        </div>
      </div>
      <div class="hero-img" aria-hidden="true">
        <img src="/img/products/cofre.svg" alt="" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">¿Para qué ocasión?</span>
        <h2>Elige por la fecha, no por el producto.</h2>
        <p class="lead">
          La mayoría de la gente no llega buscando "una placa de madera" — llega
          con un cumpleaños el sábado o un matri en marzo. Empezamos por ahí.
        </p>
      </header>
      <div class="ocasiones-grid">
        {ocasiones.map((o) => <OcasionTile ocasion={o} />)}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Lo que más sale</span>
        <h2>Productos del taller.</h2>
      </header>
      <div class="products-grid">
        {top.map((p) => <ProductCard product={p} />)}
      </div>
      <div class="section-cta">
        <a href="/productos" class="btn btn-ghost">Ver todos los productos →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Cliente feliz</span>
        <h2>Pedidos que llegaron a destino.</h2>
        <p class="lead">
          Pequeña selección de piezas entregadas. Si quieres aparecer aquí
          después de tu pedido, mándame la foto y la subimos.
        </p>
      </header>
      <div class="felices-grid">
        {clientesFelices.map((c) => <ClienteFelizCard cliente={c} />)}
      </div>
    </div>
  </section>

  <section class="section section-petroleo">
    <div class="container como-grid">
      <header class="section-header">
        <span class="eyebrow eyebrow-light">Cómo funciona</span>
        <h2 class="light">Tres pasos, sin formularios largos.</h2>
      </header>
      <ol class="pasos">
        <li>
          <span class="paso-n">01</span>
          <h3 class="light">Eliges tu pieza</h3>
          <p>Mira el catálogo, escoge ocasión y producto.</p>
        </li>
        <li>
          <span class="paso-n">02</span>
          <h3 class="light">Conversamos por WhatsApp</h3>
          <p>Me cuentas qué grabamos, te paso boceto y costo final con despacho.</p>
        </li>
        <li>
          <span class="paso-n">03</span>
          <h3 class="light">Llega a tu puerta</h3>
          <p>Lo hago en el taller, te despacho con courier y te aviso cuando salió.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section section-nogal">
    <div class="container sobre-banner">
      <div>
        <span class="eyebrow eyebrow-light">Sobre el taller</span>
        <h2 class="light">Una persona. Una máquina. Mucha madera.</h2>
        <p>
          El taller funciona con calma: pocos pedidos por semana, todos
          revisados a mano antes de despachar. No fabricamos en serie ni
          tercerizamos. Lo que sale del taller pasó por las manos de Felipe.
        </p>
        <a href="/sobre" class="btn btn-ghost btn-ghost-light">Conoce el taller →</a>
      </div>
      <div class="sobre-img" aria-hidden="true">
        <img src="/img/products/tabla-quesos.svg" alt="" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-7) 0 var(--space-8);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--space-8);
    }
  }
  .hero h1 {
    font-size: var(--fs-hero);
    line-height: 1.05;
    margin-bottom: var(--space-4);
  }
  .lead {
    font-size: var(--fs-lead);
    color: var(--color-fieltro);
    max-width: 50ch;
    margin-bottom: var(--space-5);
  }
  .hero-plazo {
    margin-bottom: var(--space-5);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .hero-img {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-tile);
    overflow: hidden;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Secciones */
  .section-header {
    margin-bottom: var(--space-6);
    max-width: 62ch;
  }
  .section-header .lead {
    margin-bottom: 0;
  }
  .section-soft {
    background: rgba(185, 205, 218, 0.18);
  }

  .ocasiones-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 600px) {
    .ocasiones-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .ocasiones-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 600px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .section-cta {
    margin-top: var(--space-6);
    text-align: center;
  }

  .felices-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  @media (min-width: 700px) {
    .felices-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Cómo funciona (sección oscura) */
  .section-petroleo {
    background: var(--color-profundo);
    color: var(--color-papel);
  }
  .section-petroleo .light,
  .section-petroleo .eyebrow-light {
    color: var(--color-papel);
  }
  .section-petroleo .eyebrow-light {
    color: var(--color-nogal);
  }
  .pasos {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 800px) {
    .pasos {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
  .pasos li {
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }
  .paso-n {
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--color-nogal);
    letter-spacing: 0.14em;
    display: block;
    margin-bottom: var(--space-2);
  }
  .pasos p {
    color: rgba(255, 255, 255, 0.78);
    font-size: var(--fs-small);
    margin: 0;
    max-width: 30ch;
  }

  /* Sección Nogal (cuerpo madera) */
  .section-nogal {
    background: var(--color-nogal);
    color: var(--color-papel);
  }
  .section-nogal .light,
  .section-nogal h2.light {
    color: var(--color-papel);
  }
  .section-nogal .eyebrow-light {
    color: rgba(255, 255, 255, 0.7);
  }
  .section-nogal p {
    color: rgba(255, 255, 255, 0.86);
  }
  .btn-ghost-light {
    color: var(--color-papel);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .btn-ghost-light:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  /* Sobre banner */
  .sobre-banner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (min-width: 800px) {
    .sobre-banner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }
  .sobre-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-tile);
  }
  .sobre-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
