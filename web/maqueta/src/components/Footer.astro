---
import { waLink, phoneDisplay, horario } from "../lib/whatsapp";
import { ocasiones } from "../data/ocasiones";
const wa = waLink({ kind: "home" });
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="col col-brand">
      <img src="/logo-horizontal.svg" alt="LáserCrafts" class="footer-logo" />
      <p class="tagline">¿Y si mejor lo hacemos bien?</p>
      <p class="razon-social">
        Borquez Solutions SpA<br/>
        Marca registrada ®<br/>
        Región de los Ríos · Chile
      </p>
    </div>

    <div class="col">
      <h4>Comprar</h4>
      <ul>
        <li><a href="/productos">Todos los productos</a></li>
        {ocasiones.slice(0, 4).map((o) => (
          <li><a href={`/productos/${o.slug}`}>{o.nombre}</a></li>
        ))}
        <li><a href="/preguntas-frecuentes">Preguntas frecuentes</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Legal</h4>
      <ul>
        <li><a href="/terminos">Términos y condiciones</a></li>
        <li><a href="/privacidad">Política de privacidad</a></li>
        <li><a href="/despachos">Política de despachos</a></li>
        <li><a href="/cambios-y-devoluciones">Cambios y devoluciones</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Conversemos</h4>
      <ul>
        <li>
          <a href={wa} target="_blank" rel="noopener">WhatsApp · {phoneDisplay}</a>
        </li>
        <li>
          <a href="https://instagram.com/lasercraftss" target="_blank" rel="noopener">Instagram · @lasercraftss</a>
        </li>
        <li>
          <a href="/contacto">Ver todos los canales</a>
        </li>
      </ul>
      <p class="horario">{horario}</p>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} LáserCrafts. Hecho en el sur de Chile.</p>
    <p><a href="/sobre">Sobre el taller</a></p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-profundo);
    color: var(--color-papel);
    margin-top: var(--space-9);
    padding-top: var(--space-8);
    padding-bottom: var(--space-5);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 700px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
      gap: var(--space-7);
    }
  }
  .col h4 {
    color: var(--color-papel);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: var(--space-3);
  }
  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .col li {
    margin-bottom: var(--space-2);
  }
  .col a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    font-size: var(--fs-small);
    transition: color 0.15s ease;
  }
  .col a:hover {
    color: var(--color-nogal);
  }
  .col-brand .footer-logo {
    height: 32px;
    color: var(--color-papel);
    margin-bottom: var(--space-4);
    /* Logo en blanco sobre el footer Profundo */
    filter: brightness(0) invert(1);
  }
  .tagline {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    color: var(--color-papel);
    margin: 0 0 var(--space-3);
    line-height: 1.2;
    max-width: 14ch;
  }
  .razon-social {
    font-size: var(--fs-small);
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.55;
  }
  .horario {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--color-papel);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer-bottom p {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: var(--fs-micro);
  }
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
  }
  .footer-bottom a:hover {
    color: var(--color-nogal);
  }
</style>
