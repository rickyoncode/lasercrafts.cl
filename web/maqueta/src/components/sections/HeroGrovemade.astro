---
import { waLink } from "../../lib/whatsapp";
import { products } from "../../data/products";

interface Props {
  enabled?: boolean;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  ctaPrimaryLabel?: string;
  ctaPrimaryHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  /** slugs de productos a mostrar en el carrusel (5–7 ideal) */
  slides?: string[];
  /** ms por slide */
  interval?: number;
  align?: "left" | "right";
  minHeight?: string;
}

const {
  enabled = true,
  eyebrow = "Taller chileno · Madera grabada",
  title = "El regalo",
  subtitle = "En terciado del sur, grabado a láser, despachado en días.",
  ctaPrimaryLabel = "Ver catálogo",
  ctaPrimaryHref = "/productos",
  ctaSecondaryLabel = "Conversemos por WhatsApp",
  ctaSecondaryHref = waLink({ kind: "home" }),
  slides = [
    "cofre-tapa-hojas",
    "posavasos-fauna-nativa",
    "marcapaginas-fauna",
    "cuadro-3d-pez-betta",
    "llaveros-fauna-nativa",
  ],
  interval = 4500,
  align = "right",
  minHeight = "620px",
} = Astro.props;

if (!enabled) return null;

const carouselItems = slides
  .map((slug) => products.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<section class:list={["hero-gm", `hero-gm--${align}`]} style={`--hero-gm-min: ${minHeight};`}>
  <div class="hero-gm-carousel container" data-carousel data-interval={interval}>
    {carouselItems.map((p, i) => (
      <a
        href={`/producto/${p.slug}`}
        class:list={["hero-gm-slide", i === 0 && "is-active"]}
        data-slide-index={i}
        aria-label={`Ver ${p.nombre}`}
      >
        <img src={`/img/products/catalogo/transparent/${p.slug}.png`} alt={p.nombre} loading={i === 0 ? "eager" : "lazy"} />
      </a>
    ))}
    <div class="hero-gm-dots" role="tablist" aria-label="Productos destacados">
      {carouselItems.map((p, i) => (
        <button
          type="button"
          class:list={["hero-gm-dot", i === 0 && "is-active"]}
          data-dot-index={i}
          role="tab"
          aria-label={p.nombre}
          aria-selected={i === 0}
        ></button>
      ))}
    </div>
  </div>

  <div class="hero-gm-inner container">
    <div class="hero-gm-copy">
      {eyebrow && <span class="eyebrow eyebrow-light">{eyebrow}</span>}
      <h1 class="hero-gm-title">{title}</h1>
      {subtitle && <p class="hero-gm-subtitle">{subtitle}</p>}
      <div class="hero-gm-actions">
        <a href={ctaPrimaryHref} class="btn hero-gm-btn-primary">{ctaPrimaryLabel}</a>
        {ctaSecondaryHref && (
          <a href={ctaSecondaryHref} target="_blank" rel="noopener" class="btn hero-gm-btn-ghost" data-wa-context="hero-gm">
            {ctaSecondaryLabel}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const root = document.querySelector<HTMLDivElement>("[data-carousel]");
    if (!root) return;
    const slides = root.querySelectorAll<HTMLElement>(".hero-gm-slide");
    const dots = root.querySelectorAll<HTMLButtonElement>(".hero-gm-dot");
    const interval = Number(root.dataset.interval || 4500);
    let idx = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function show(next: number) {
      idx = (next + slides.length) % slides.length;
      slides.forEach((el, i) => el.classList.toggle("is-active", i === idx));
      dots.forEach((el, i) => {
        el.classList.toggle("is-active", i === idx);
        el.setAttribute("aria-selected", i === idx ? "true" : "false");
      });
    }
    function start() {
      stop();
      timer = setInterval(() => show(idx + 1), interval);
    }
    function stop() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        show(i);
        start();
      });
    });
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    start();
  })();
</script>

<style>
  .hero-gm {
    position: relative;
    min-height: var(--hero-gm-min);
    color: var(--color-papel);
    background:
      radial-gradient(120% 80% at 80% 30%, #143b76 0%, #0a2547 60%, #06182f 100%);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Carrusel: vive dentro del container del sitio (alineado con el logo).
     Solo el background es full-width — el contenido respeta max-content. */
  .hero-gm-carousel {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 100%;
    width: 100%;
    z-index: 1;
    pointer-events: none;
  }
  .hero-gm-slide {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 50%;
    max-width: 540px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    opacity: 0;
    transition: opacity 0.9s ease;
    pointer-events: none;
  }
  .hero-gm-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .hero-gm-slide img {
    width: auto;
    height: 64%;
    max-height: 400px;
    max-width: 82%;
    object-fit: contain;
    filter: drop-shadow(0 22px 40px rgba(0, 0, 0, 0.55));
  }

  /* Dots */
  .hero-gm-dots {
    position: absolute;
    bottom: var(--space-5);
    left: 0;
    width: 50%;
    max-width: 540px;
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    z-index: 3;
    pointer-events: auto;
  }
  .hero-gm-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: transparent;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .hero-gm-dot.is-active {
    background: var(--color-papel);
    transform: scale(1.2);
  }
  .hero-gm-dot:focus-visible {
    outline: 2px solid var(--color-papel);
    outline-offset: 2px;
  }

  /* Copy a la derecha (sobre el carrusel) */
  .hero-gm-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    padding-top: var(--space-7);
    padding-bottom: var(--space-7);
  }
  .hero-gm--right .hero-gm-inner { justify-content: flex-end; }
  .hero-gm--left  .hero-gm-inner { justify-content: flex-start; }

  .hero-gm-copy {
    max-width: 32ch;
    text-align: left;
  }
  .hero-gm--right .hero-gm-copy { text-align: right; }

  .hero-gm .eyebrow-light {
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: var(--space-3);
  }

  .hero-gm-title {
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    color: var(--color-papel);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-3);
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
  }
  .hero-gm-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--fs-lead);
    line-height: 1.4;
    margin: 0 0 var(--space-5);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }
  .hero-gm-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .hero-gm--right .hero-gm-actions { justify-content: flex-end; }

  .hero-gm-btn-primary {
    background: var(--color-papel);
    color: var(--color-profundo);
    padding: 0.9rem 1.6rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--color-papel);
    letter-spacing: 0.02em;
  }
  .hero-gm-btn-primary:hover {
    background: rgba(255, 255, 255, 0.92);
  }
  .hero-gm-btn-ghost {
    background: transparent;
    color: var(--color-papel);
    padding: 0.9rem 1.6rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
  }
  .hero-gm-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 900px) {
    .hero-gm-slide img {
      max-width: 60%;
      height: 60%;
      max-height: 380px;
    }
  }

  @media (max-width: 720px) {
    .hero-gm { min-height: 620px; }
    .hero-gm-inner {
      justify-content: flex-start !important;
      padding-top: var(--space-6);
      padding-bottom: var(--space-8);
      align-items: flex-end;
    }
    .hero-gm-copy { text-align: left !important; max-width: 28ch; }
    .hero-gm-actions { justify-content: flex-start !important; }
    .hero-gm-title { font-size: clamp(2rem, 9vw, 3rem); }
    .hero-gm-slide {
      width: 100%;
      max-width: 100%;
      justify-content: center;
    }
    .hero-gm-slide img {
      height: 42%;
      max-width: 72%;
      transform: translateY(-18%);
    }
    .hero-gm-dots { left: 50%; transform: translateX(-50%); top: 40%; bottom: auto; }
  }
</style>
