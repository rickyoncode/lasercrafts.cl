---
import "../styles/global.css";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { waLink, phoneDisplay } from "../lib/whatsapp";
import { langs, empresasUrl, empresasCopy } from "../i18n/empresas";
import type { Lang } from "../i18n/empresas";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = empresasCopy[lang];
const wa = waLink({ kind: "empresas", lang });
const canonical = new URL(empresasUrl(lang), Astro.site).toString();
const ogLocale = lang === "es" ? "es_CL" : lang === "pt" ? "pt_BR" : "en_US";

const alternates = langs.map((l) => ({
  lang: l,
  hreflang: l === "es" ? "es-cl" : l === "pt" ? "pt-br" : "en",
  url: new URL(empresasUrl(l), Astro.site).toString(),
}));
const xDefault = new URL(empresasUrl("es"), Astro.site).toString();
---

<!doctype html>
<html lang={copy.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{copy.meta.title}</title>
    <meta name="description" content={copy.meta.description} />

    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.url} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <link rel="icon" type="image/svg+xml" href="/logo-redondo.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={copy.meta.title} />
    <meta property="og:description" content={copy.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/empresas/casos/futangue/page-1.png", Astro.site).toString()} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.meta.title} />
    <meta name="twitter:description" content={copy.meta.description} />

    <meta name="theme-color" content="#0D4080" />
  </head>
  <body>
    <a href="#main" class="skip-link">{copy.htmlLang.startsWith("en") ? "Skip to content" : copy.htmlLang.startsWith("pt") ? "Pular para o conteúdo" : "Saltar al contenido"}</a>

    <header class="emp-header">
      <div class="container emp-header-row">
        <a href={empresasUrl(lang)} class="emp-logo-link" aria-label="LáserCrafts">
          <img src="/logo-horizontal.svg" alt="" class="emp-logo-img" />
        </a>
        <div class="emp-header-right">
          <LanguageSwitcher current={lang} label={copy.switcher.label} />
          <a href={wa} target="_blank" rel="noopener" class="btn btn-primary emp-header-cta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.6 6.3A8 8 0 0 0 4.3 16l-1.1 4 4.1-1.1A8 8 0 1 0 17.6 6.3zm-5.6 12.5h-.1a6.6 6.6 0 0 1-3.4-.9l-.2-.1-2.4.6.6-2.4-.2-.2a6.6 6.6 0 0 1 10.3-8 6.6 6.6 0 0 1-4.6 11.3zm3.6-4.9-1.3-.5c-.2 0-.3 0-.4.1l-.6.7c-.1.2-.2.2-.4.1a5.4 5.4 0 0 1-2.7-2.4c-.1-.2 0-.4.1-.5l.4-.5a.4.4 0 0 0 0-.4l-.6-1.3c-.1-.4-.3-.3-.4-.3h-.4c-.1 0-.4.1-.6.3a1.8 1.8 0 0 0-.6 1.4 3 3 0 0 0 .7 1.6 7 7 0 0 0 2.8 2.5c.4.2.7.3 1 .4.4.1.7.1 1 0 .4 0 .9-.4 1.1-.7.1-.4.1-.7.1-.8 0-.1-.1-.2-.3-.3z"/>
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="emp-footer">
      <div class="container emp-footer-row">
        <div class="emp-footer-brand">
          <img src="/logo-horizontal.svg" alt="LáserCrafts" class="emp-footer-logo" />
          <p class="emp-footer-razon">{copy.footer.razonSocial}</p>
          <p class="emp-footer-tagline">{copy.footer.tagline}</p>
        </div>
        <div class="emp-footer-cols">
          <div class="emp-footer-col">
            <p class="emp-footer-kicker">{copy.footer.otrosIdiomas}</p>
            <ul role="list">
              {
                langs.filter((l) => l !== lang).map((l) => (
                  <li><a href={empresasUrl(l)} hreflang={l}>{l === "es" ? "Español" : l === "pt" ? "Português" : "English"}</a></li>
                ))
              }
            </ul>
          </div>
          <div class="emp-footer-col">
            <p class="emp-footer-kicker">WhatsApp</p>
            <a href={wa} target="_blank" rel="noopener">{phoneDisplay}</a>
          </div>
          <div class="emp-footer-col">
            <p class="emp-footer-kicker">B2C</p>
            <a href="/">{copy.footer.volverTienda}</a>
          </div>
        </div>
      </div>
    </footer>

    <style>
      .emp-header {
        border-bottom: 1px solid var(--color-profundo-08);
        background: var(--color-papel);
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: saturate(180%) blur(8px);
      }
      .emp-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        min-height: 64px;
        padding-top: var(--space-2);
        padding-bottom: var(--space-2);
      }
      .emp-logo-link {
        color: var(--color-profundo);
        display: inline-flex;
        align-items: center;
      }
      .emp-logo-img {
        height: 36px;
        width: auto;
        color: var(--color-profundo);
      }
      .emp-header-right {
        display: flex;
        align-items: center;
        gap: var(--space-4);
      }
      .emp-header-cta {
        display: none;
        padding: 0.625rem 1rem;
        font-size: var(--fs-small);
      }
      @media (min-width: 700px) {
        .emp-header-cta {
          display: inline-flex;
        }
      }

      .emp-footer {
        background: var(--color-profundo);
        color: var(--color-papel);
        padding: var(--space-8) 0 var(--space-7);
        margin-top: var(--space-9);
      }
      .emp-footer-row {
        display: grid;
        gap: var(--space-7);
      }
      @media (min-width: 768px) {
        .emp-footer-row {
          grid-template-columns: 1.4fr 2fr;
          align-items: start;
        }
      }
      .emp-footer-brand {
        max-width: 28rem;
      }
      .emp-footer-logo {
        height: 32px;
        color: var(--color-papel);
        margin-bottom: var(--space-4);
      }
      .emp-footer-razon {
        font-size: var(--fs-small);
        opacity: 0.84;
        margin-bottom: var(--space-2);
      }
      .emp-footer-tagline {
        font-family: var(--font-display);
        font-size: var(--fs-h3);
        line-height: 1.2;
        opacity: 0.92;
        margin: 0;
      }
      .emp-footer-cols {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-5);
      }
      .emp-footer-kicker {
        font-family: var(--font-mono);
        font-size: var(--fs-micro);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        opacity: 0.6;
        margin: 0 0 var(--space-3);
      }
      .emp-footer-cols ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }
      .emp-footer-cols a {
        color: var(--color-papel);
        text-decoration: none;
        font-size: var(--fs-small);
        opacity: 0.92;
        transition: opacity 0.15s ease;
      }
      .emp-footer-cols a:hover {
        opacity: 1;
        text-decoration: underline;
      }
    </style>
  </body>
</html>

<style is:global>
  main {
    min-height: 60vh;
  }
</style>
